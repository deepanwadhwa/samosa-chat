#!/bin/sh
# samosa — chat with Qwen3.6-35B-A3B locally. No cloud, no account, no telemetry.
#
#   samosa "explain how DNS works"          answer a question
#   samosa --continue "and DNSSEC?"         follow up on the last conversation
#   samosa --think "hard logic puzzle"      general reasoning profile
#   samosa --think-code "build a page"      precise coding/WebDev profile
#   samosa --fast "..."                     adaptive thermal thread scaling (faster, runs warmer)
#   samosa --seed N "..."                   reproducible sampling
#   samosa --max-tokens N "..."             override the safety ceiling
#   samosa --thinking-budget N "..."         cap internal reasoning before the answer
#   samosa serve                            run the local app server in foreground
#   samosa serve --stop                     stop the local app server cleanly
#   samosa app                              start the server and open the browser app
#   samosa pull                             pull the 24 GB model to local volume
#   samosa doctor                           check the installation
#
# Conversations resume instantly from a small snapshot — your chat history
# never has to be re-processed, even after a reboot.

set -eu

HOME_DIR="${SAMOSA_HOME:-$HOME/.samosa}"
SELF_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
if [ -n "${SAMOSA_RELEASE_DIR:-}" ]; then
  RELEASE_DIR=$SAMOSA_RELEASE_DIR
elif [ -x "$SELF_DIR/qwen36b" ] && [ -d "$SELF_DIR/../model" ]; then
  RELEASE_DIR=$(CDPATH= cd -- "$SELF_DIR/.." && pwd)
else
  RELEASE_DIR=$HOME_DIR
fi
ENGINE="$RELEASE_DIR/bin/qwen36b"
MODEL="$RELEASE_DIR/model"
TOKENIZER="$RELEASE_DIR/tokenizer_qwen36.json"
APP_HTML="$RELEASE_DIR/app.html"
APP_LOGO="$RELEASE_DIR/samosa-chat.png"
SESSION="$HOME_DIR/last_session.qws"
PORT="${SAMOSA_PORT:-8642}"
PID_FILE="$HOME_DIR/server.pid"
SERVER_LOG="$HOME_DIR/server.log"
CURL="${SAMOSA_CURL:-curl}"
if [ "$(uname -s)" = "Darwin" ]; then
  OPEN="${SAMOSA_OPEN:-open}"
else
  OPEN="${SAMOSA_OPEN:-xdg-open}"
fi

PROFILE="direct"
TOKENS=""
THINKING_BUDGET=""
RESUME=""
SEED=""

say()  { printf '\033[1;36m[samosa]\033[0m %s\n' "$*"; }
fail() { printf '\033[1;31m[samosa] ERROR:\033[0m %s\n' "$*" >&2; exit 1; }

sha256_file() {
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$1" | awk '{print $1}'
  elif command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$1" | awk '{print $1}'
  else
    fail "neither sha256sum nor shasum is available"
  fi
}

pull_model() {
  BASE_URL="${SAMOSA_BASE_URL:-https://huggingface.co/REPO_ID_PLACEHOLDER/resolve/main}"
  MODEL_DIR="/model"
  mkdir -p "$MODEL_DIR"
  MANIFEST="$MODEL_DIR/release-manifest.tsv"
  
  say "Fetching release manifest..."
  "$CURL" -fL --retry 5 --retry-delay 3 --progress-bar \
    "$BASE_URL/release-manifest.tsv" -o "$MANIFEST.next" \
    || fail "release manifest download failed"
    
  awk -F '\t' '
    NF != 3 || length($1) != 64 || $1 !~ /^[0-9a-f]+$/ || $2 !~ /^[0-9]+$/ ||
    $3 == "" || $3 ~ /^\// || $3 ~ /(^|\/)\.\.(\/|$)/ { exit 1 }
  ' "$MANIFEST.next" || fail "release manifest is malformed or unsafe"
  
  mv -f "$MANIFEST.next" "$MANIFEST"
  
  # We only pull the model files and the tokenizer to the volume
  PULL_FILES="experts.bin resident.safetensors manifest.json config.json generation_config.json tokenizer_qwen36.json"
  
  manifest_field() {
    awk -F '\t' -v p="$1" -v c="$2" '$3==p {print $c; found=1} END {if(!found) exit 1}' "$MANIFEST"
  }
  
  verified() {
    want=$(manifest_field "$1" 1) || return 1
    size=$(manifest_field "$1" 2) || return 1
    [ -f "$2" ] || return 1
    [ "$(wc -c <"$2" | tr -d ' ')" = "$size" ] || return 1
    have=$(sha256_file "$2")
    [ "$want" = "$have" ]
  }
  
  fetch() {
    relative=$1; target=$2
    say "downloading $relative ..."
    "$CURL" -fL --retry 5 --retry-delay 3 -C - --progress-bar \
      "$BASE_URL/$relative" -o "$target" \
      || fail "download failed for $relative - re-run to resume"
  }
  
  for relative in $PULL_FILES; do
    target="$MODEL_DIR/$relative"
    if verified "$relative" "$target"; then
      say "$relative already verified - skipping"
    else
      fetch "$relative" "$target"
      verified "$relative" "$target" ||
        fail "checksum mismatch for $relative"
    fi
  done
  
  say "Model pull complete."
}

usage() { sed -n '2,18p' "$0" | sed 's/^# \{0,1\}//'; exit 0; }

positive_integer() {
  case "$1" in ''|*[!0-9]*|0) return 1 ;; *) return 0 ;; esac
}

server_running() {
  "$CURL" -fsS --max-time 1 "http://127.0.0.1:$PORT/healthz" >/dev/null 2>&1
}

serve_foreground() {
  mkdir -p "$HOME_DIR/chats"
  SNAP="$MODEL" TOKENIZER="$TOKENIZER" SAMOSA_CHATS_DIR="$HOME_DIR/chats" \
    SAMOSA_APP_HTML="$APP_HTML" SAMOSA_APP_LOGO="$APP_LOGO" \
    exec "$ENGINE" --serve --port "$PORT" --tokenizer "$TOKENIZER"
}

start_server() {
  server_running && return 0
  mkdir -p "$HOME_DIR/chats"
  if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE" 2>/dev/null)" 2>/dev/null; then
    echo "Samosa server process exists but is not healthy; see $SERVER_LOG" >&2
    return 1
  fi
  nohup env SNAP="$MODEL" TOKENIZER="$TOKENIZER" SAMOSA_CHATS_DIR="$HOME_DIR/chats" \
    SAMOSA_APP_HTML="$APP_HTML" SAMOSA_APP_LOGO="$APP_LOGO" \
    "$ENGINE" --serve --port "$PORT" --tokenizer "$TOKENIZER" \
    >"$SERVER_LOG" 2>&1 &
  pid=$!
  printf '%s\n' "$pid" >"$PID_FILE"
  i=0
  while [ "$i" -lt 240 ]; do
    server_running && return 0
    if ! kill -0 "$pid" 2>/dev/null; then
      echo "Samosa server failed to start; see $SERVER_LOG" >&2
      rm -f "$PID_FILE"
      return 1
    fi
    sleep 0.5
    i=$((i + 1))
  done
  echo "Samosa server did not become ready within 120 seconds; see $SERVER_LOG" >&2
  return 1
}

stop_server() {
  if server_running; then
    "$CURL" -fsS --max-time 5 -X POST "http://127.0.0.1:$PORT/v1/shutdown" >/dev/null || true
  fi
  if [ -f "$PID_FILE" ]; then
    pid=$(cat "$PID_FILE" 2>/dev/null || true)
    i=0
    while [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null && [ "$i" -lt 50 ]; do
      sleep 0.1
      i=$((i + 1))
    done
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      kill -TERM "$pid" 2>/dev/null || true
    fi
    rm -f "$PID_FILE"
  fi
  echo "Samosa server stopped."
}

doctor() {
  ok=1
  [ "$RELEASE_DIR" = "$HOME_DIR" ] || echo "release:   $(basename "$RELEASE_DIR")"
  [ -x "$ENGINE" ] && echo "engine:    ok ($ENGINE)" || { echo "engine:    MISSING - re-run the installer"; ok=0; }
  [ -f "$MODEL/experts.bin" ] && echo "model:     ok ($(du -sh "$MODEL" 2>/dev/null | awk '{print $1}'))" || { echo "model:     MISSING"; ok=0; }
  if [ -f "$MODEL/manifest.json" ]; then
    if grep -q 'groupwise-q4-gate-up-row-q8-down-v1' "$MODEL/manifest.json"; then
      echo "format:    mixed group-q4 gate/up + row-q8 down (experimental)"
    elif grep -q 'groupwise-symmetric-q4-v1' "$MODEL/manifest.json"; then
      group=$(sed -n 's/.*"group_size"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p' "$MODEL/manifest.json" | head -1)
      echo "format:    groupwise q4 (group ${group:-unknown})"
    else
      echo "format:    LEGACY whole-row q4 - upgrade required"
    fi
  else
    echo "format:    UNKNOWN (manifest missing)"
    ok=0
  fi
  [ -f "$TOKENIZER" ] && echo "tokenizer: ok" || { echo "tokenizer: MISSING"; ok=0; }
  if [ -d "$HOME_DIR/releases" ]; then
    releases=$(find "$HOME_DIR/releases" -mindepth 1 -maxdepth 1 -type d ! -name '.*.partial' 2>/dev/null | wc -l | tr -d ' ')
    [ "$releases" -le 1 ] || echo "rollback:  $((releases - 1)) previous verified release(s) retained"
  fi
  [ ! -d "$HOME_DIR/model" ] || [ "$RELEASE_DIR" = "$HOME_DIR" ] ||
    echo "legacy:    ~/.samosa/model retained from the pre-versioned installer"
  [ -f "$SESSION" ] && echo "session:   $(du -h "$SESSION" | awk '{print $1}') (samosa --continue works)" || echo "session:   none yet"
  IN_CONTAINER=0
  if [ -f /.dockerenv ] || grep -q 'docker\|containerd' /proc/self/cgroup 2>/dev/null; then
    IN_CONTAINER=1
  fi
  
  if [ "$IN_CONTAINER" = 1 ]; then
    echo "env:       container"
    if [ -f /sys/fs/cgroup/memory.max ]; then
      max_bytes=$(cat /sys/fs/cgroup/memory.max)
      if [ "$max_bytes" = "max" ]; then
        echo "ram:       unlimited (cgroup)"
      else
        RAM_GB=$((max_bytes / 1073741824))
        echo "ram:       $RAM_GB GB (cgroup)"
        if [ "$RAM_GB" -lt 6 ]; then
          echo "WARNING:   cgroup limit is less than 6 GB. Raise Docker Desktop VM RAM."
        fi
      fi
    else
      echo "ram:       unknown (cgroup)"
    fi
    
    # Check mount type to warn about virtiofs/9p slow mounts
    mount_device=$(df -P "$MODEL" 2>/dev/null | awk 'NR==2 {print $1}')
    mount_type=$(awk -v m="$MODEL" '$2==m {print $3}' /proc/mounts 2>/dev/null)
    if [ -z "$mount_type" ]; then
      mount_type=$(awk -v m="$(df -P "$MODEL" 2>/dev/null | awk 'NR==2 {print $6}')" '$2==m {print $3}' /proc/mounts 2>/dev/null)
    fi
    if [ "$mount_type" = "virtiofs" ] || [ "$mount_type" = "9p" ] || [ "$mount_type" = "fakeowner" ] || [ "$mount_type" = "osxfs" ] || [ "$mount_type" = "grpcfuse" ] || echo "$mount_device" | grep -q -E 'virtiofs|9p|host|grpcfuse'; then
      echo "WARNING:   model is mounted via ${mount_type:-9p/virtiofs} ($mount_device). This causes a 10x slowdown. Use a named Docker volume instead."
    fi
  else
    if [ "$(uname -s)" = "Darwin" ]; then
      RAM_GB=$(( $(sysctl -n hw.memsize) / 1073741824 ))
    else
      RAM_KB=$(awk '/MemTotal/ {print $2}' /proc/meminfo)
      RAM_GB=$(( RAM_KB / 1048576 ))
    fi
    echo "ram:       $RAM_GB GB"
  fi
  [ "$ok" = 1 ] && echo "all good." || exit 1
}

if [ "${1:-}" = "pull" ]; then
  shift
  [ "$#" = 0 ] || usage
  pull_model
  exit 0
fi

if [ "${1:-}" = "serve" ]; then
  shift
  if [ "${1:-}" = "--stop" ]; then
    [ "$#" = 1 ] || usage
    stop_server
    exit 0
  fi
  [ "$#" = 0 ] || usage
  serve_foreground
fi

if [ "${1:-}" = "app" ]; then
  shift
  [ "$#" = 0 ] || usage
  start_server
  url="http://127.0.0.1:$PORT"
  echo "$url"
  "$OPEN" "$url"
  exit 0
fi

while [ $# -gt 0 ]; do
  case "$1" in
    --continue) [ -f "$SESSION" ] && RESUME=1 || echo "(no previous conversation - starting fresh)" ;;
    --think)    PROFILE="think" ;;
    --think-code) PROFILE="think-code" ;;
    --fast)
      SAMOSA_FAST=1
      export SAMOSA_FAST
      ;;
    --seed)
      shift
      [ $# -gt 0 ] && positive_integer "$1" || { echo "--seed requires a positive integer" >&2; exit 1; }
      SEED="$1"
      ;;
    --max-tokens)
      shift
      [ $# -gt 0 ] && positive_integer "$1" || { echo "--max-tokens requires a positive integer" >&2; exit 1; }
      TOKENS="$1"
      ;;
    --thinking-budget)
      shift
      [ $# -gt 0 ] && positive_integer "$1" || { echo "--thinking-budget requires a positive integer" >&2; exit 1; }
      THINKING_BUDGET="$1"
      ;;
    doctor)     doctor; exit 0 ;;
    -h|--help)  usage ;;
    --*)        echo "unknown flag: $1 (try: samosa --help)"; exit 1 ;;
    *)          break ;;
  esac
  shift
done

[ $# -gt 0 ] || usage
PROMPT="$*"

[ -n "$TOKENS" ] || TOKENS=8192
case "$PROFILE" in
  direct)     THINKING_BUDGET="" ;;
  think)      [ -n "$THINKING_BUDGET" ] || THINKING_BUDGET=1024 ;;
  think-code) [ -n "$THINKING_BUDGET" ] || THINKING_BUDGET=2048 ;;
esac

if [ -n "$RESUME" ]; then
  set -- --resume-session "$SESSION" --chat "$PROMPT"
else
  set -- --chat "$PROMPT"
fi

case "$PROFILE" in
  direct)     set -- "$@" --no-thinking ;;
  think)      : ;;
  think-code) set -- "$@" --thinking-code ;;
esac

set -- "$@" --stream --tokens "$TOKENS" --tokenizer "$TOKENIZER" \
  --save-session "$SESSION"
[ -z "$SEED" ] || set -- "$@" --seed "$SEED"
[ -z "$THINKING_BUDGET" ] || set -- "$@" --thinking-budget "$THINKING_BUDGET"

SNAP="$MODEL" exec "$ENGINE" "$@" 2>/dev/null
